{
  "name": "studio-mcleod",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:client": "wait-on http-get://localhost:8080/health && vite --host 0.0.0.0",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:release-notes": "tsx scripts/build-release-notes.ts",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.716.0",
    "@aws-sdk/s3-request-presigner": "3.716.0",
    "archiver": "7.0.1",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "17.4.2",
    "express": "4.21.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "6.12.0",
    "multer": "2.2.0",
    "pino": "10.3.1",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/archiver": "6.0.3",
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.7",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.4.20",
    "concurrently": "9.1.0",
    "lucide-react": "1.22.0",
    "postcss": "8.4.49",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vite": "8.1.0",
    "vitest": "2.1.8",
    "wait-on": "^9.0.10"
  }
}
